{
  "openapi": "3.0.3",
  "info": {
    "title": "jma-openapi",
    "version": "0.1.0",
    "description": "気象庁防災情報 JSON を扱いやすい REST API として公開する非公式ラッパー API。\n"
  },
  "servers": [
    {
      "url": "http://localhost:8080",
      "description": "local"
    },
    {
      "url": "https://example.run.app",
      "description": "cloud-run"
    }
  ],
  "tags": [
    {
      "name": "health"
    },
    {
      "name": "areas"
    },
    {
      "name": "forecasts"
    }
  ],
  "paths": {
    "/healthz": {
      "get": {
        "tags": [
          "health"
        ],
        "operationId": "getHealthz",
        "summary": "Liveness check",
        "description": "アプリケーション自身の liveness を返す。",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          },
          "default": {
            "$ref": "#/components/responses/ErrorResponse"
          }
        }
      }
    },
    "/v1/areas": {
      "get": {
        "tags": [
          "areas"
        ],
        "operationId": "getV1Areas",
        "summary": "List area metadata",
        "description": "気象庁の office 一覧を返す。`parent`、`name`、`officeName`、`child` は完全一致の AND 条件として扱い、0 件時は `200` と空の `items` を返す。",
        "parameters": [
          {
            "in": "query",
            "name": "parent",
            "schema": {
              "type": "string"
            },
            "required": false,
            "description": "offices.parent でのフィルタ。"
          },
          {
            "in": "query",
            "name": "name",
            "schema": {
              "type": "string"
            },
            "required": false,
            "description": "offices.name でのフィルタ。"
          },
          {
            "in": "query",
            "name": "nameMatchMode",
            "schema": {
              "$ref": "#/components/schemas/AreaMatchMode"
            },
            "required": false,
            "description": "`name` に適用する検索モード。未指定時は `exact`。"
          },
          {
            "in": "query",
            "name": "officeName",
            "schema": {
              "type": "string"
            },
            "required": false,
            "description": "offices.officeName での完全一致フィルタ。"
          },
          {
            "in": "query",
            "name": "child",
            "schema": {
              "type": "string"
            },
            "required": false,
            "description": "offices.children に含まれる child code での完全一致フィルタ。"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AreasResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/ErrorResponse"
          },
          "502": {
            "$ref": "#/components/responses/ErrorResponse"
          },
          "503": {
            "$ref": "#/components/responses/ErrorResponse"
          },
          "default": {
            "$ref": "#/components/responses/ErrorResponse"
          }
        }
      }
    },
    "/v1/areas/{areaCode}": {
      "get": {
        "tags": [
          "areas"
        ],
        "operationId": "getV1AreasAreaCode",
        "summary": "Get a single area metadata",
        "description": "指定した office code の詳細を返す。",
        "parameters": [
          {
            "in": "path",
            "name": "areaCode",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Area"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/ErrorResponse"
          },
          "502": {
            "$ref": "#/components/responses/ErrorResponse"
          },
          "503": {
            "$ref": "#/components/responses/ErrorResponse"
          },
          "default": {
            "$ref": "#/components/responses/ErrorResponse"
          }
        }
      }
    },
    "/v1/forecasts/{officeCode}": {
      "get": {
        "tags": [
          "forecasts"
        ],
        "operationId": "getV1ForecastsOfficeCode",
        "summary": "Get forecast by office code",
        "description": "指定した office code の予報情報を返す。",
        "parameters": [
          {
            "in": "path",
            "name": "officeCode",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ForecastResponse"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/ErrorResponse"
          },
          "502": {
            "$ref": "#/components/responses/ErrorResponse"
          },
          "503": {
            "$ref": "#/components/responses/ErrorResponse"
          },
          "default": {
            "$ref": "#/components/responses/ErrorResponse"
          }
        }
      }
    },
    "/v1/forecasts/{officeCode}/areas/{areaCode}": {
      "get": {
        "tags": [
          "forecasts"
        ],
        "operationId": "getV1ForecastsOfficeCodeAreasAreaCode",
        "summary": "Get forecast for a weather area by office code",
        "description": "指定した office code の forecast から、`weatherAreas.code` または `temperatureAreas.code` に一致する対象のみを返す。",
        "parameters": [
          {
            "in": "path",
            "name": "officeCode",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "path",
            "name": "areaCode",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ForecastAreaResponse"
                }
              }
            }
          },
          "404": {
            "description": "officeCode が不正、または areaCode に一致する weatherArea / temperatureArea が存在しない。",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorEnvelope"
                }
              }
            }
          },
          "502": {
            "$ref": "#/components/responses/ErrorResponse"
          },
          "503": {
            "$ref": "#/components/responses/ErrorResponse"
          },
          "default": {
            "$ref": "#/components/responses/ErrorResponse"
          }
        }
      }
    },
    "/v1/forecasts/{officeCode}/areas": {
      "get": {
        "tags": [
          "forecasts"
        ],
        "operationId": "getV1ForecastsOfficeCodeAreas",
        "summary": "List forecast areas by office code",
        "description": "指定した office code の forecast に含まれる weather / temperature area の統合一覧を返す。",
        "parameters": [
          {
            "in": "path",
            "name": "officeCode",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ForecastAreaListResponse"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/ErrorResponse"
          },
          "default": {
            "$ref": "#/components/responses/ErrorResponse"
          }
        }
      }
    },
    "/v1/forecasts/{officeCode}/weather-areas": {
      "get": {
        "tags": [
          "forecasts"
        ],
        "operationId": "getV1ForecastsOfficeCodeWeatherAreas",
        "summary": "List weather areas by office code",
        "description": "指定した office code の weather area 一覧を返す。",
        "parameters": [
          {
            "in": "path",
            "name": "officeCode",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WeatherAreaListResponse"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/ErrorResponse"
          },
          "default": {
            "$ref": "#/components/responses/ErrorResponse"
          }
        }
      }
    },
    "/v1/forecasts/{officeCode}/weather-areas/{areaCode}": {
      "get": {
        "tags": [
          "forecasts"
        ],
        "operationId": "getV1ForecastsOfficeCodeWeatherAreasAreaCode",
        "summary": "Get weather area forecast by office code",
        "description": "指定した office code 配下の weather area ひとつ分の予報情報を返す。",
        "parameters": [
          {
            "in": "path",
            "name": "officeCode",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "path",
            "name": "areaCode",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WeatherAreaResponse"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/ErrorResponse"
          },
          "default": {
            "$ref": "#/components/responses/ErrorResponse"
          }
        }
      }
    },
    "/v1/forecasts/{officeCode}/temperature-areas": {
      "get": {
        "tags": [
          "forecasts"
        ],
        "operationId": "getV1ForecastsOfficeCodeTemperatureAreas",
        "summary": "List temperature areas by office code",
        "description": "指定した office code の temperature area 一覧を返す。",
        "parameters": [
          {
            "in": "path",
            "name": "officeCode",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TemperatureAreaListResponse"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/ErrorResponse"
          },
          "default": {
            "$ref": "#/components/responses/ErrorResponse"
          }
        }
      }
    },
    "/v1/forecasts/{officeCode}/temperature-areas/{areaCode}": {
      "get": {
        "tags": [
          "forecasts"
        ],
        "operationId": "getV1ForecastsOfficeCodeTemperatureAreasAreaCode",
        "summary": "Get temperature area forecast by office code",
        "description": "指定した office code 配下の temperature area ひとつ分の予報情報を返す。",
        "parameters": [
          {
            "in": "path",
            "name": "officeCode",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "path",
            "name": "areaCode",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TemperatureAreaResponse"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/ErrorResponse"
          },
          "default": {
            "$ref": "#/components/responses/ErrorResponse"
          }
        }
      }
    },
    "/v1/forecasts/{officeCode}/areas:resolve": {
      "get": {
        "tags": [
          "forecasts"
        ],
        "operationId": "getV1ForecastsOfficeCodeAreasResolve",
        "summary": "Resolve forecast area codes by name",
        "description": "指定した office code 配下の area 名から候補 code 一覧を返す。",
        "parameters": [
          {
            "in": "path",
            "name": "officeCode",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "q",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "query",
            "name": "kind",
            "required": false,
            "schema": {
              "$ref": "#/components/schemas/ForecastAreaKind"
            }
          },
          {
            "in": "query",
            "name": "matchMode",
            "required": false,
            "schema": {
              "$ref": "#/components/schemas/AreaMatchMode"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ForecastAreaListResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/ErrorResponse"
          },
          "404": {
            "$ref": "#/components/responses/ErrorResponse"
          },
          "default": {
            "$ref": "#/components/responses/ErrorResponse"
          }
        }
      }
    },
    "/v1/forecasts/{officeCode}/areas/{areaCode}/latest": {
      "get": {
        "tags": [
          "forecasts"
        ],
        "operationId": "getV1ForecastsOfficeCodeAreasAreaCodeLatest",
        "summary": "Get latest forecast area entry by area code",
        "description": "指定した area code の時系列先頭要素のみを返す。",
        "parameters": [
          {
            "in": "path",
            "name": "officeCode",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "path",
            "name": "areaCode",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ForecastAreaResponse"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/ErrorResponse"
          },
          "default": {
            "$ref": "#/components/responses/ErrorResponse"
          }
        }
      }
    },
    "/v1/forecasts/{officeCode}/areas/{areaCode}/timeseries": {
      "get": {
        "tags": [
          "forecasts"
        ],
        "operationId": "getV1ForecastsOfficeCodeAreasAreaCodeTimeseries",
        "summary": "Get forecast area timeseries by area code",
        "description": "指定した area code の時系列全体を返す。",
        "parameters": [
          {
            "in": "path",
            "name": "officeCode",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "in": "path",
            "name": "areaCode",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ForecastAreaResponse"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/ErrorResponse"
          },
          "default": {
            "$ref": "#/components/responses/ErrorResponse"
          }
        }
      }
    }
  },
  "components": {
    "responses": {
      "ErrorResponse": {
        "description": "Error",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorEnvelope"
            }
          }
        }
      }
    },
    "schemas": {
      "HealthResponse": {
        "type": "object",
        "required": [
          "status",
          "service",
          "version",
          "timestamp"
        ],
        "properties": {
          "status": {
            "type": "string",
            "example": "ok"
          },
          "service": {
            "type": "string",
            "example": "jma-openapi"
          },
          "version": {
            "type": "string",
            "example": "0.1.0"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "AreasResponse": {
        "type": "object",
        "required": [
          "items"
        ],
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Area"
            }
          }
        }
      },
      "AreaMatchMode": {
        "type": "string",
        "enum": [
          "exact",
          "prefix",
          "partial",
          "suggested"
        ]
      },
      "Area": {
        "type": "object",
        "required": [
          "code",
          "name",
          "enName",
          "officeName",
          "parent",
          "children"
        ],
        "properties": {
          "code": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "enName": {
            "type": "string"
          },
          "officeName": {
            "type": "string"
          },
          "parent": {
            "type": "string"
          },
          "children": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "ForecastResponse": {
        "type": "object",
        "required": [
          "office",
          "publishingOffice",
          "reportDatetime",
          "weatherAreas",
          "temperatureAreas"
        ],
        "properties": {
          "office": {
            "$ref": "#/components/schemas/OfficeRef"
          },
          "publishingOffice": {
            "type": "string"
          },
          "reportDatetime": {
            "type": "string",
            "format": "date-time"
          },
          "weatherAreas": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/WeatherArea"
            }
          },
          "temperatureAreas": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TemperatureArea"
            }
          }
        }
      },
      "ForecastAreaResponse": {
        "type": "object",
        "required": [
          "office",
          "publishingOffice",
          "reportDatetime"
        ],
        "description": "area code 個別予報レスポンス。`weatherArea` または `temperatureArea` のいずれか一方を返す。",
        "properties": {
          "office": {
            "$ref": "#/components/schemas/OfficeRef"
          },
          "publishingOffice": {
            "type": "string"
          },
          "reportDatetime": {
            "type": "string",
            "format": "date-time"
          },
          "weatherArea": {
            "$ref": "#/components/schemas/WeatherArea"
          },
          "temperatureArea": {
            "$ref": "#/components/schemas/TemperatureArea"
          }
        }
      },
      "ForecastAreaKind": {
        "type": "string",
        "enum": [
          "weather",
          "temperature",
          "any"
        ]
      },
      "ForecastAreaRef": {
        "type": "object",
        "required": [
          "kind",
          "code",
          "name"
        ],
        "properties": {
          "kind": {
            "$ref": "#/components/schemas/ForecastAreaKind"
          },
          "code": {
            "type": "string"
          },
          "name": {
            "type": "string"
          }
        }
      },
      "ForecastAreaListResponse": {
        "type": "object",
        "required": [
          "items"
        ],
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ForecastAreaRef"
            }
          }
        }
      },
      "WeatherAreaListResponse": {
        "type": "object",
        "required": [
          "items"
        ],
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ForecastAreaRef"
            }
          }
        }
      },
      "TemperatureAreaListResponse": {
        "type": "object",
        "required": [
          "items"
        ],
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ForecastAreaRef"
            }
          }
        }
      },
      "WeatherAreaResponse": {
        "type": "object",
        "required": [
          "office",
          "publishingOffice",
          "reportDatetime",
          "weatherArea"
        ],
        "properties": {
          "office": {
            "$ref": "#/components/schemas/OfficeRef"
          },
          "publishingOffice": {
            "type": "string"
          },
          "reportDatetime": {
            "type": "string",
            "format": "date-time"
          },
          "weatherArea": {
            "$ref": "#/components/schemas/WeatherArea"
          }
        }
      },
      "TemperatureAreaResponse": {
        "type": "object",
        "required": [
          "office",
          "publishingOffice",
          "reportDatetime",
          "temperatureArea"
        ],
        "properties": {
          "office": {
            "$ref": "#/components/schemas/OfficeRef"
          },
          "publishingOffice": {
            "type": "string"
          },
          "reportDatetime": {
            "type": "string",
            "format": "date-time"
          },
          "temperatureArea": {
            "$ref": "#/components/schemas/TemperatureArea"
          }
        }
      },
      "OfficeRef": {
        "type": "object",
        "required": [
          "code",
          "name"
        ],
        "properties": {
          "code": {
            "type": "string"
          },
          "name": {
            "type": "string"
          }
        }
      },
      "WeatherArea": {
        "type": "object",
        "required": [
          "code",
          "name",
          "timeSeries"
        ],
        "properties": {
          "code": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "timeSeries": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/WeatherTimeSeriesEntry"
            }
          }
        }
      },
      "WeatherTimeSeriesEntry": {
        "type": "object",
        "required": [
          "time"
        ],
        "properties": {
          "time": {
            "type": "string",
            "format": "date-time"
          },
          "weatherCode": {
            "type": "string",
            "nullable": true
          },
          "weather": {
            "type": "string",
            "nullable": true
          },
          "wind": {
            "type": "string",
            "nullable": true
          },
          "wave": {
            "type": "string",
            "nullable": true
          },
          "pop": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "TemperatureArea": {
        "type": "object",
        "required": [
          "code",
          "name",
          "timeSeries"
        ],
        "properties": {
          "code": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "timeSeries": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TemperatureTimeSeriesEntry"
            }
          }
        }
